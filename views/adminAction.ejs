<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Actions</title>
</head>
<body>
    <%- include('header') %>


    <div class="mb-3">
        <label for="country-select" class="form-label">Select Country</label>
        <select class="form-control" id="country-select">
          <option value="">All Countries</option>
          <% countries.forEach(country => { %>
            <option value="<%= country %>"><%= country %></option>
          <% }) %>
        </select>
      </div>

    <div class="container mt-5">
        <h2>Emissions Factor</h2>
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addCountryModal">Add New Country</button>
        <table id="emissions-table" class="table table-striped">
            <thead>
                <tr>
                    <th>Country</th>
                    <th>Component</th>
                    <th>Emissions Factor</th>
                    <th>Edit</th>
                </tr>
            </thead>
            <tbody>
                <% emissions.forEach(emission => { %>
                    <tr>
                        <td><%= emission.country %></td>
                        <td><%= emission.component %></td>
                        <td><%= emission.emissions_factor %></td>
                        <td>
                            <button class="btn btn-primary edit-button" data-bs-toggle="modal" data-bs-target="#editEmissionModal">Edit</button>
                          </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>

    <!-- Add emissions component Modal -->
    <div class="modal fade" id="addCountryModal" tabindex="-1" aria-labelledby="addCountryModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="addCountryModalLabel">Add New Country</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form id="add-country-form">
                        <div class="mb-3">
                            <label for="country" class="form-label">Country</label>
                            <input type="text" class="form-control" id="country" required>
                        </div>
                        <div class="mb-3">
                            <label for="component" class="form-label">Component</label>
                            <input type="text" class="form-control" id="component" required>
                        </div>
                        <div class="mb-3">
                            <label for="emissions-factor" class="form-label">Emissions Factor</label>
                            <input type="number" step="any" class="form-control" id="emissions-factor" required>
                        </div>
                        <button type="submit" class="btn btn-primary">Add Country</button>
                    </form>
                </div>
            </div>
        </div>
    </div>



    <!-- Edit Emission Modal -->
<div class="modal fade" id="editEmissionModal" tabindex="-1" aria-labelledby="editEmissionModalLabel" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="editEmissionModalLabel">Edit Emission</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <form id="edit-emission-form">
            <input type="hidden" id="edit-id">
            <div class="mb-3">
              <label for="edit-country" class="form-label">Country</label>
              <input type="text" class="form-control" id="edit-country" required disabled>
            </div>
            <div class="mb-3">
              <label for="edit-component" class="form-label">Component</label>
              <input type="text" class="form-control" id="edit-component" required disabled>
            </div>
            <div class="mb-3">
              <label for="edit-emissions-factor" class="form-label">Emissions Factor</label>
              <input type="number" step="any" class="form-control" id="edit-emissions-factor" required>
            </div>
            <button type="submit" class="btn btn-primary">Update Emission</button>
          </form>
        </div>
      </div>
    </div>
  </div>
  

    <%- include('footer') %>
    <script>
        // Initialize DataTable and get reference to instance
        const table = $('#emissions-table').DataTable();
    
        // Get reference to the dropdown
        const select = document.querySelector('#country-select');
    
        // Add an event listener to the dropdown
        select.addEventListener('change', function() {
            // Get the selected country
            const country = this.value;
    
            // Filter table using DataTables API
            // Use column().search() for specific column search
            table.column(0).search(country).draw();
        });
    
        document.getElementById('add-country-form').addEventListener('submit', async (event) => {
            event.preventDefault();
            const country = document.getElementById('country').value;
            const component = document.getElementById('component').value;
            const emissionsFactor = document.getElementById('emissions-factor').value;
    
            try {
                const response = await fetch('/admin/api/emissions', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        country,
                        component,
                        emissions_factor: emissionsFactor
                    })
                });
    
                if (response.ok) {
                    toastr.success('Successfully added country emissions data');
                    location.reload();
                } else {
                    toastr.error('Failed to add country emissions data');
                }
            } catch (error) {
                toastr.error(error);
            }
        });




       



        table.on('click', '.edit-button', (event) => {
  const row = table.row($(event.target).closest('tr'));
  const data = row.data();

  console.log('Row data:', data);

  document.getElementById('edit-country').value = data[0];
  document.getElementById('edit-component').value = data[1];
  document.getElementById('edit-emissions-factor').value = data[2];

  const modal = new bootstrap.Modal(document.getElementById('editEmissionModal'));
  modal.show();
});

document.getElementById('edit-emission-form').addEventListener('submit', async (event) => {
  event.preventDefault();

  const country = document.getElementById('edit-country').value;
  const component = document.getElementById('edit-component').value;
  const emissionsFactor = document.getElementById('edit-emissions-factor').value;

  console.log('Form values:', country, component, emissionsFactor);

  try {
    const response = await axios.patch(`/admin/api/emissions/${country}/${component}`, {
      emissions_factor: emissionsFactor
    });

    console.log('Response:', response);

    if (response.status === 200) {
      toastr.success('Successfully updated emissions data');
      location.reload();
    }
  } catch (error) {
    console.log('Error:', error);
    toastr.error('Failed to update emissions data');
  }
});


</script>

    
</body>
</html>

