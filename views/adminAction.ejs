<%- include('header') %>

<div class="container py-4">
  <div class="page-header-bar d-flex align-items-center justify-content-between flex-wrap gap-2">
    <div>
      <h2><i class="fa-solid fa-sliders me-2"></i>Emissions Config</h2>
      <p>Manage country electricity grid emission factors.</p>
    </div>
    <a href="/admin/welcome" class="btn btn-eco-outline fw-semibold" style="border-color:white;color:white;">
      <i class="fa-solid fa-arrow-left me-2"></i>Dashboard
    </a>
  </div>

  <div class="row mb-3">
    <div class="col-md-4">
      <label for="country-select" class="form-label fw-semibold">Filter by Country</label>
      <select class="form-select" id="country-select">
        <option value="">All Countries</option>
        <% countries.forEach(function(country) { %>
          <option value="<%= country %>"><%= country %></option>
        <% }) %>
      </select>
    </div>
    <div class="col-md-8 d-flex align-items-end justify-content-end">
      <button class="btn btn-eco fw-semibold" data-bs-toggle="modal" data-bs-target="#addCountryModal">
        <i class="fa-solid fa-plus me-2"></i>Add / Update Factor
      </button>
    </div>
  </div>

  <div class="table-container">
    <h5 class="section-title">Emission Factors</h5>
    <div class="table-responsive">
      <table id="emissions-table" class="table table-hover align-middle">
        <thead class="table-dark">
          <tr>
            <th>Country Code</th>
            <th>Component</th>
            <th>Factor (kg CO₂e/kWh)</th>
            <th>Edit</th>
          </tr>
        </thead>
        <tbody>
          <% emissions.forEach(function(e) { %>
            <tr>
              <td><strong><%= e.country %></strong></td>
              <td><%= e.component %></td>
              <td><%= Number(e.emissions_factor).toFixed(3) %></td>
              <td>
                <button class="btn btn-sm btn-eco edit-button">
                  <i class="fa-solid fa-pen me-1"></i>Edit
                </button>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Add Modal -->
<div class="modal fade" id="addCountryModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header" style="background:var(--clr-primary);color:white;">
        <h5 class="modal-title"><i class="fa-solid fa-plus me-2"></i>Add / Update Factor</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <form id="add-country-form" action="/admin/api/emissions" method="POST">
          <div class="mb-3">
            <label class="form-label fw-semibold">Country Code (ISO)</label>
            <input type="text" class="form-control" id="country" name="country" placeholder="e.g. GB, US, DE" required>
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">Component</label>
            <input type="text" class="form-control" id="component" name="component" value="device_usage" required>
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">Emissions Factor (kg CO₂e/kWh)</label>
            <input type="number" step="0.001" min="0" class="form-control" id="emissions-factor" name="emissions_factor" required>
          </div>
          <button type="submit" class="btn btn-eco w-100 fw-semibold">Save Factor</button>
        </form>
      </div>
    </div>
  </div>
</div>

<!-- Edit Modal -->
<div class="modal fade" id="editEmissionModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header" style="background:var(--clr-secondary);color:white;">
        <h5 class="modal-title"><i class="fa-solid fa-pen me-2"></i>Edit Emission Factor</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <form id="edit-emission-form">
          <div class="mb-3">
            <label class="form-label fw-semibold">Country Code</label>
            <input type="text" class="form-control" id="edit-country" disabled>
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">Component</label>
            <input type="text" class="form-control" id="edit-component" disabled>
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">Emissions Factor</label>
            <input type="number" step="0.001" min="0" class="form-control" id="edit-emissions-factor" required>
          </div>
          <button type="submit" class="btn btn-eco w-100 fw-semibold">Update Factor</button>
        </form>
      </div>
    </div>
  </div>
</div>

<script>
$(document).ready(function () {
  const table = $('#emissions-table').DataTable({ pageLength: 25 });

  $('#country-select').on('change', function () {
    table.column(0).search(this.value).draw();
  });

  table.on('click', '.edit-button', function (event) {
    const row = table.row($(event.currentTarget).closest('tr'));
    const data = row.data();
    document.getElementById('edit-country').value = data[0];
    document.getElementById('edit-component').value = data[1];
    document.getElementById('edit-emissions-factor').value = data[2];
    new bootstrap.Modal(document.getElementById('editEmissionModal')).show();
  });

  document.getElementById('edit-emission-form').addEventListener('submit', async function (e) {
    e.preventDefault();
    const country = document.getElementById('edit-country').value;
    const component = document.getElementById('edit-component').value;
    const factor = document.getElementById('edit-emissions-factor').value;
    try {
      const resp = await axios.patch(`/admin/api/emissions/${country}/${component}`, { emissions_factor: factor });
      if (resp.status === 200) {
        toastr.success('Factor updated');
        location.reload();
      }
    } catch {
      toastr.error('Failed to update factor');
    }
  });
});
</script>

<%- include('footer') %>
