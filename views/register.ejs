<%- include('header') %>

<div class="auth-wrapper">
  <div class="auth-card">
    <div class="auth-header">
      <i class="fa-solid fa-user-plus fa-2x opacity-80"></i>
      <h4>Create Account</h4>
      <p class="mb-0 small opacity-80">Join Sustainable Tech Calculator</p>
    </div>
    <div class="auth-body">
      <form id="register-form" action="/auth/register" method="post">
        <div class="mb-3">
          <label for="username" class="form-label fw-semibold">Username</label>
          <input type="text" name="username" id="username" class="form-control" placeholder="Choose a username" required>
        </div>
        <div class="mb-3">
          <label for="email" class="form-label fw-semibold">Email</label>
          <input type="email" name="email" id="email" class="form-control" placeholder="your@email.com" required>
        </div>
        <div class="mb-3">
          <label for="password" class="form-label fw-semibold">Password</label>
          <input type="password" name="password" id="password" class="form-control" placeholder="Create a password" required>
        </div>
        <div class="mb-4">
          <label for="role" class="form-label fw-semibold">Account Type</label>
          <select name="role" id="role" class="form-select" required>
            <option value="user" selected>User — calculate emissions</option>
            <option value="vendor">Vendor — submit product data</option>
          </select>
        </div>
        <button type="submit" class="btn btn-eco w-100 py-2 fw-semibold">
          <i class="fa-solid fa-leaf me-2"></i>Create Account
        </button>
      </form>

      <hr class="my-3">
      <p class="text-center mb-0 small text-muted">
        Already have an account? <a href="/auth/login" class="text-eco fw-semibold">Sign in here</a>
      </p>
    </div>
  </div>
</div>

<script>
$(document).ready(function () {
  $('#register-form').submit(function (event) {
    event.preventDefault();
    $.ajax({
      url: '/auth/register',
      type: 'POST',
      data: $(this).serialize(),
      success: function () {
        toastr.success('Registration successful! You can now log in.');
        setTimeout(function () { window.location.href = '/auth/login'; }, 2000);
      },
      error: function (jqXHR) {
        const msg = jqXHR.status === 400
          ? JSON.parse(jqXHR.responseText).error
          : 'Internal server error';
        toastr.error(msg);
      }
    });
  });
});
</script>

<%- include('footer') %>
