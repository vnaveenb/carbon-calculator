<%- include('header') %>

<div class="container py-4">
  <div class="page-header-bar d-flex align-items-center justify-content-between flex-wrap gap-2">
    <div>
      <h2><i class="fa-solid fa-gauge-high me-2"></i>Dashboard</h2>
      <p>Welcome back, <strong><%= user.username %></strong> &mdash; <%= user.email %></p>
    </div>
    <a href="/user/actions" class="btn btn-eco-accent fw-semibold">
      <i class="fa-solid fa-calculator me-2"></i>Go to Calculator
    </a>
  </div>

  <div class="table-container">
    <h5 class="section-title">Search History</h5>
    <div class="table-responsive">
      <table id="search-history-table" class="table table-hover align-middle">
        <thead class="table-dark">
          <tr>
            <th>Brand</th>
            <th>Model</th>
            <th>Location</th>
            <th>Years</th>
            <th>Qty</th>
            <th>Total CO₂ (kg)</th>
          </tr>
        </thead>
        <tbody></tbody>
      </table>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', async () => {
  try {
    const response = await fetch('/user/search-history');
    const history = await response.json();
    const tbody = document.querySelector('#search-history-table tbody');
    tbody.innerHTML = '';
    for (const item of history) {
      const row = document.createElement('tr');
      row.innerHTML = `
        <td>${item.brand || ''}</td>
        <td>${item.model || ''}</td>
        <td>${item.location || ''}</td>
        <td>${item.years || ''}</td>
        <td>${item.quantity || ''}</td>
        <td><strong>${Number(item.total_carbon_emissions || 0).toFixed(2)}</strong></td>
      `;
      tbody.appendChild(row);
    }
    $('#search-history-table').DataTable({ pageLength: 10, order: [] });
  } catch (e) {
    console.error('Error loading history:', e);
  }
});
</script>

<%- include('footer') %>
