  <title>App</title>
  <style>

.container, .container-fluid, .container-lg, .container-md, .container-sm, .container-xl {
    
    margin-left: 20px !important;
}



    .dropdown {
      margin-left: auto;
    }

    .dropdown button {
      border-radius: 60%;
      font-size: 1.2rem;
      padding: 15px 10px;
    }

    .dropdown-menu {
      right: 4px;
      left: auto;
    }

    .dropdown-menu.show {
    left: auto;
    display: block;
}
  </style>
