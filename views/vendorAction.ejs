<%- include('header') %>

<div class="container py-4">
  <div class="page-header-bar d-flex align-items-center justify-content-between flex-wrap gap-2">
    <div>
      <h2><i class="fa-solid fa-upload me-2"></i>Upload Data</h2>
      <p>Submit or update product carbon emissions data.</p>
    </div>
    <a href="/vendor/welcome" class="btn btn-eco-outline fw-semibold" style="border-color:white;color:white;">
      <i class="fa-solid fa-arrow-left me-2"></i>Dashboard
    </a>
  </div>

  <!-- Tabs -->
  <ul class="nav nav-tabs mb-4" id="vendorTabs" role="tablist">
    <li class="nav-item" role="presentation">
      <button class="nav-link active fw-semibold" id="upload-tab" data-bs-toggle="tab" data-bs-target="#upload" type="button">
        <i class="fa-solid fa-upload me-2"></i>Upload Data
      </button>
    </li>
    <li class="nav-item" role="presentation">
      <button class="nav-link fw-semibold" id="view-tab" data-bs-toggle="tab" data-bs-target="#view" type="button">
        <i class="fa-solid fa-table-list me-2"></i>View Data
      </button>
    </li>
  </ul>

  <div class="tab-content">

    <!-- ── Upload Tab ── -->
    <div class="tab-pane fade show active" id="upload" role="tabpanel">

      <!-- XLS Upload card -->
      <div class="table-container mb-4">
        <h5 class="section-title">Import from Excel</h5>
        <p class="text-muted small">Upload an Excel file with your product emissions data. Don't have a template?
          <a href="/vendor/test.xlsx" download class="text-eco fw-semibold">Download template</a>
        </p>
        <button type="button" class="btn btn-eco" data-bs-toggle="modal" data-bs-target="#uploadModal">
          <i class="fa-solid fa-file-excel me-2"></i>Upload Excel File
        </button>
      </div>

      <!-- Manual Entry card -->
      <div class="table-container">
        <h5 class="section-title">Manual Entry</h5>
        <form id="vendor-form">
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label fw-semibold">Brand</label>
              <input type="text" class="form-control" name="brand" placeholder="e.g. HP, Apple, Dell" required>
            </div>
            <div class="col-md-6">
              <label class="form-label fw-semibold">Model</label>
              <input type="text" class="form-control" name="model" placeholder="e.g. EliteBook 855 G7" required>
            </div>
            <div class="col-md-4">
              <label class="form-label fw-semibold">Total CO₂ (kg)</label>
              <input type="number" step="0.01" class="form-control" name="total_co2" placeholder="0.00">
            </div>
            <div class="col-md-4">
              <label class="form-label fw-semibold">Chassis (kg)</label>
              <input type="number" step="0.01" class="form-control" name="chassis" placeholder="0.00">
            </div>
            <div class="col-md-4">
              <label class="form-label fw-semibold">Storage Drive (kg)</label>
              <input type="number" step="0.01" class="form-control" name="storage_drive" placeholder="0.00">
            </div>
            <div class="col-md-4">
              <label class="form-label fw-semibold">Power Supply (kg)</label>
              <input type="number" step="0.01" class="form-control" name="power_supply_unit" placeholder="0.00">
            </div>
            <div class="col-md-4">
              <label class="form-label fw-semibold">Battery (kg)</label>
              <input type="number" step="0.01" class="form-control" name="battery" placeholder="0.00">
            </div>
            <div class="col-md-4">
              <label class="form-label fw-semibold">Mainboard / SOC (kg)</label>
              <input type="number" step="0.01" class="form-control" name="soc" placeholder="0.00">
            </div>
            <div class="col-md-4">
              <label class="form-label fw-semibold">Display (kg)</label>
              <input type="number" step="0.01" class="form-control" name="display" placeholder="0.00">
            </div>
            <div class="col-md-4">
              <label class="form-label fw-semibold">Packaging (kg)</label>
              <input type="number" step="0.01" class="form-control" name="packaging" placeholder="0.00">
            </div>
            <div class="col-md-4">
              <label class="form-label fw-semibold">Optical Drive (kg)</label>
              <input type="number" step="0.01" class="form-control" name="optical_drive" placeholder="0.00">
            </div>
            <div class="col-md-4">
              <label class="form-label fw-semibold">Transportation (kg)</label>
              <input type="number" step="0.01" class="form-control" name="transportation" placeholder="0.00">
            </div>
            <div class="col-md-4">
              <label class="form-label fw-semibold">End of Life (kg)</label>
              <input type="number" step="0.01" class="form-control" name="end_of_life" placeholder="0.00">
            </div>
            <div class="col-md-4">
              <label class="form-label fw-semibold">Device Usage (kg)</label>
              <input type="number" step="0.01" class="form-control" name="device_usage" placeholder="0.00">
            </div>
            <div class="col-12 mt-2">
              <button type="submit" class="btn btn-eco fw-semibold px-4">
                <i class="fa-solid fa-floppy-disk me-2"></i>Submit Data
              </button>
            </div>
          </div>
        </form>
      </div>
    </div>

    <!-- ── View Tab ── -->
    <div class="tab-pane fade" id="view" role="tabpanel">
      <div class="table-container">
        <h5 class="section-title">Your Submissions</h5>
        <div class="table-responsive">
          <table id="vendor-data-table" class="table table-hover align-middle">
            <thead class="table-dark">
              <tr>
                <th>Brand</th><th>Model</th><th>Total CO₂</th>
                <th>Chassis</th><th>Storage</th><th>PSU</th>
                <th>Battery</th><th>SOC</th><th>Display</th>
                <th>Device Usage</th>
              </tr>
            </thead>
            <tbody></tbody>
          </table>
        </div>
      </div>
    </div>

  </div>
</div>

<!-- Upload Modal -->
<div class="modal fade" id="uploadModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header" style="background:var(--clr-primary);color:white;">
        <h5 class="modal-title"><i class="fa-solid fa-file-excel me-2"></i>Upload Excel File</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <form id="xls-upload-form" enctype="multipart/form-data">
          <div class="mb-3">
            <label class="form-label fw-semibold">Select .xlsx file</label>
            <input type="file" class="form-control" name="xlsFile" accept=".xls,.xlsx" required>
          </div>
          <p class="small text-muted">Don't have a file? <a href="/vendor/test.xlsx" download class="text-eco">Download the template</a> first.</p>
          <button type="submit" class="btn btn-eco w-100 fw-semibold">
            <i class="fa-solid fa-upload me-2"></i>Upload
          </button>
        </form>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
      </div>
    </div>
  </div>
</div>

<script>
// XLS Upload
document.getElementById('xls-upload-form').addEventListener('submit', async function (e) {
  e.preventDefault();
  const formData = new FormData(this);
  try {
    const resp = await fetch('/vendor/upload-xls', { method: 'POST', body: formData });
    const data = await resp.json();
    if (data.success) {
      toastr.success(data.message || 'Upload successful');
      bootstrap.Modal.getInstance(document.getElementById('uploadModal')).hide();
    } else {
      toastr.error(data.message || 'Upload failed');
    }
  } catch {
    toastr.error('Upload failed');
  }
});

// Manual form submit
document.getElementById('vendor-form').addEventListener('submit', async function (e) {
  e.preventDefault();
  const body = Object.fromEntries(new FormData(this));
  try {
    const resp = await fetch('/vendor/submit-emissions-data', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body)
    });
    const data = await resp.json();
    if (data.success) {
      toastr.success('Data submitted successfully');
      this.reset();
    } else {
      toastr.error(data.message || 'Submission failed');
    }
  } catch {
    toastr.error('Submission failed');
  }
});

// Load vendor data on View tab click
document.getElementById('view-tab').addEventListener('click', async function () {
  if ($.fn.DataTable.isDataTable('#vendor-data-table')) return;
  try {
    const resp = await fetch('/vendor/fetch-data');
    const rows = await resp.json();
    const tbody = document.querySelector('#vendor-data-table tbody');
    tbody.innerHTML = '';
    rows.forEach(r => {
      const tr = document.createElement('tr');
      tr.innerHTML = `
        <td>${r.brand || ''}</td><td>${r.model || ''}</td>
        <td>${Number(r.total_co2 || 0).toFixed(2)}</td>
        <td>${Number(r.chassis || 0).toFixed(2)}</td>
        <td>${Number(r.storage_drive || 0).toFixed(2)}</td>
        <td>${Number(r.power_supply_unit || 0).toFixed(2)}</td>
        <td>${Number(r.battery || 0).toFixed(2)}</td>
        <td>${Number(r.soc || 0).toFixed(2)}</td>
        <td>${Number(r.display || 0).toFixed(2)}</td>
        <td>${Number(r.device_usage || 0).toFixed(2)}</td>
      `;
      tbody.appendChild(tr);
    });
    $('#vendor-data-table').DataTable({ pageLength: 15 });
  } catch (err) {
    toastr.error('Failed to load data');
  }
});
</script>

<%- include('footer') %>
