<%- include('header') %>

<!-- Hero Section -->
<section class="page-hero">
  <div class="container">
    <div class="mb-3">
      <i class="fa-solid fa-earth-americas fa-3x opacity-75"></i>
    </div>
    <h1>Your Carbon Footprint Calculator</h1>
    <p class="lead">Understand the environmental impact of your devices. Make informed, sustainable choices — one laptop at a time.</p>
    <div class="d-flex flex-wrap justify-content-center gap-3 mt-4">
      <a class="btn btn-eco-accent btn-lg px-4" href="/user/actions">
        <i class="fa-solid fa-calculator me-2"></i>Try as Guest
      </a>
      <a class="btn btn-eco-outline btn-lg px-4" href="/auth/login">
        <i class="fa-solid fa-right-to-bracket me-2"></i>Login
      </a>
      <a class="btn btn-eco-outline btn-lg px-4" href="/register">
        <i class="fa-solid fa-user-plus me-2"></i>Register
      </a>
    </div>
  </div>
</section>

<!-- Feature Cards -->
<section class="py-5">
  <div class="container">
    <h2 class="text-center section-title d-inline-block mb-4">What You Can Do</h2>
    <div class="row g-4 justify-content-center">
      <div class="col-md-4">
        <div class="feature-card">
          <div class="feature-icon"><i class="fa-solid fa-magnifying-glass-chart"></i></div>
          <h5>Calculate Footprint</h5>
          <p class="text-muted mb-0">Select any laptop or device from our database of 250+ products and instantly see its full lifecycle carbon emissions.</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="feature-card">
          <div class="feature-icon"><i class="fa-solid fa-scale-balanced"></i></div>
          <h5>Compare Devices</h5>
          <p class="text-muted mb-0">Add multiple products side-by-side and compare their emissions across all lifecycle stages in an interactive chart.</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="feature-card">
          <div class="feature-icon"><i class="fa-solid fa-file-arrow-down"></i></div>
          <h5>Export Reports</h5>
          <p class="text-muted mb-0">Download a detailed PDF report with charts and emissions data — perfect for sustainability reporting or procurement decisions.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- How it Works -->
<section class="py-4 pb-5" style="background: var(--clr-white);">
  <div class="container">
    <h2 class="text-center section-title d-inline-block mb-4">How It Works</h2>
    <div class="row g-4 justify-content-center text-center">
      <div class="col-md-3">
        <div class="p-3">
          <div class="rounded-circle bg-eco text-white d-inline-flex align-items-center justify-content-center mb-3" style="width:56px;height:56px;font-size:1.4rem;font-weight:700;">1</div>
          <h6 class="fw-semibold">Pick a Device</h6>
          <p class="text-muted small">Choose a brand and model from Apple, HP, Dell, Lenovo, Microsoft and more.</p>
        </div>
      </div>
      <div class="col-md-3">
        <div class="p-3">
          <div class="rounded-circle bg-eco text-white d-inline-flex align-items-center justify-content-center mb-3" style="width:56px;height:56px;font-size:1.4rem;font-weight:700;">2</div>
          <h6 class="fw-semibold">Set Your Region</h6>
          <p class="text-muted small">Select your country — the usage emissions are adjusted for local electricity grid intensity.</p>
        </div>
      </div>
      <div class="col-md-3">
        <div class="p-3">
          <div class="rounded-circle bg-eco text-white d-inline-flex align-items-center justify-content-center mb-3" style="width:56px;height:56px;font-size:1.4rem;font-weight:700;">3</div>
          <h6 class="fw-semibold">See Your Impact</h6>
          <p class="text-muted small">Get a full breakdown: manufacturing, transport, usage, and end-of-life emissions.</p>
        </div>
      </div>
      <div class="col-md-3">
        <div class="p-3">
          <div class="rounded-circle bg-eco text-white d-inline-flex align-items-center justify-content-center mb-3" style="width:56px;height:56px;font-size:1.4rem;font-weight:700;">4</div>
          <h6 class="fw-semibold">Take Action</h6>
          <p class="text-muted small">Download your report and make smarter, more sustainable purchasing choices.</p>
        </div>
      </div>
    </div>
    <div class="text-center mt-4">
      <a class="btn btn-eco btn-lg px-5" href="/user/actions">
        <i class="fa-solid fa-bolt me-2"></i>Start Calculating Now
      </a>
    </div>
  </div>
</section>

<%- include('footer') %>
