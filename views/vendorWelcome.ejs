<%- include('header') %>

<div class="container py-4">
  <div class="page-header-bar">
    <h2><i class="fa-solid fa-gauge-high me-2"></i>Vendor Dashboard</h2>
    <p>Welcome, <strong><%= user.username %></strong> &mdash; <%= user.email %></p>
  </div>

  <div class="row g-4">
    <div class="col-md-6">
      <div class="feature-card text-start">
        <div class="feature-icon"><i class="fa-solid fa-upload"></i></div>
        <h5>Upload Emissions Data</h5>
        <p class="text-muted">Submit product carbon footprint data via Excel file or manual entry to contribute to the database.</p>
        <a href="/vendor/action" class="btn btn-eco mt-2">
          <i class="fa-solid fa-upload me-2"></i>Upload Data
        </a>
      </div>
    </div>
    <div class="col-md-6">
      <div class="feature-card text-start">
        <div class="feature-icon"><i class="fa-solid fa-table-list"></i></div>
        <h5>View Your Submissions</h5>
        <p class="text-muted">Review and update the product emissions data you have previously submitted to the platform.</p>
        <a href="/vendor/action" class="btn btn-eco mt-2">
          <i class="fa-solid fa-eye me-2"></i>View Data
        </a>
      </div>
    </div>
  </div>
</div>

<%- include('footer') %>
