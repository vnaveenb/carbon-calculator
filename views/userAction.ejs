  initializeForm(document.querySelector('.product-form-container'));



  document.querySelector('#remove-product').addEventListener('click', () => {
    const productFormContainers = document.querySelectorAll('.card');
    if (productFormContainers.length > 1) {
      productFormContainers[productFormContainers.length - 1].remove();
    }
  });


  document.addEventListener('DOMContentLoaded', async () => {
      const response = await fetch('/user/unique-brands');
      const brands = await response.json();

      const form = document.querySelector('#carbon-emission-form');
      
      const brandDropdown = form.querySelector('.brand');
      brands.forEach(brand => {
        const option = document.createElement('option');
        option.value = brand;
        option.textContent = brand;
        brandDropdown.appendChild(option);
      });
    });


    document.querySelector('#add-product').addEventListener('click', async () => {
    const productFormsContainer = document.querySelector('.product-forms-container');
    const newProductFormContainer = createNewProductFormContainer();
    productFormsContainer.appendChild(newProductFormContainer);
    
    const response = await fetch('/user/unique-brands');
    const brands = await response.json();

    const form = newProductFormContainer.querySelector('form');
    
    const brandDropdown = form.querySelector('.brand');
    brands.forEach(brand => {
      const option = document.createElement('option');
      option.value = brand;
      option.textContent = brand;
      brandDropdown.appendChild(option);
    });

    initializeForm(newProductFormContainer);  // Initialize the form after populating the dropdown
