  function updateTableAndCharts(chartDataArray) {
  console.log("Received chart data:", chartDataArray);

  const totalEmissions = {};
  const categories = [
    'transportation',
    'packaging',
    'display',
    'soc',
    'battery',
    'power_supply_unit',
    'optical_drive',
    'storage_drive',
    'chassis',
    'end_of_life',
    'device_usage',
  ];

  const scopes = {
    'transportation': 'Scope 1',
    'packaging': 'Scope 1',
    'display': 'Scope 1',
    'soc': 'Scope 1',
    'battery': 'Scope 1',
    'power_supply_unit': 'Scope 1',
    'optical_drive': 'Scope 1',
    'storage_drive': 'Scope 1',
    'chassis': 'Scope 1',
    'end_of_life': 'Scope 3',
    'device_usage': 'Scope 2',
  };

  // Populate totalEmissions with the sum of each category's emissions
  chartDataArray.forEach((productData) => {
    categories.forEach((category) => {
      if (!totalEmissions[category]) {
        totalEmissions[category] = 0;
      }
      totalEmissions[category] += productData[category];
    });
  });

  // Calculate sumOfTotalEmissions
  let sumOfTotalEmissions = Object.values(totalEmissions).reduce((a, b) => a + b, 0);




// Get a reference to the table header
const tableHead = document.querySelector('#emissions-detailed-table-separate thead');
tableHead.innerHTML = '';
const headerRow = document.createElement('tr');

