  <style>
.chart-container {
  position: relative;
  width: 50vw;
  height: 50vh;
}



.product-forms-container {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
  }



  .product-form-container {
  box-sizing: border-box;
  flex-basis: calc(50% - 20px);
  grid-template-columns: repeat(2, 1fr);
  grid-gap: 16px;
}

.card-body {
    
    padding: initial!important;
}



  .card {
    box-shadow: 0 4px 8px 0 rgba(0, 0, 0, 0.2);
    padding: 16px;
    width: 30vw !important;
    height: 63vh !important;
  }

 

 

  .quantity,
  .years {
    grid-column: span 2;
  }


  .chart-wrapper {
  display: flex;
  justify-content: center;
  align-items: center;
}

.chart-container,
.bar-chart-container {
  flex: 1;
  margin: 10px;
}

.chart-container canvas,
.bar-chart-container canvas {
  display: block;
  max-width: 100%;
  height: auto;
  margin: 0 auto;
}

.bar-chart-container {
    position: relative;
    width: fit-content;
    height: fit-content;
  }

  .form-card {
  margin-bottom: 20px;
  margin-top: 20px;
  margin-left: 20px;
  margin-right: 20px;
}


