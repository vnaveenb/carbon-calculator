  const barCanvas = await html2canvas(barChart);
  const barChartImg = barCanvas.toDataURL('image/png');
  pdf.addImage(barChartImg, 'PNG', 420, 50, 400, 400);

  // Add border around text
  pdf.setLineWidth(1);
  pdf.rect(10, 1000, pdf.internal.pageSize.getWidth() - 20, 150);
  pdf.setFontSize(12);
  // Add text about each category of emissions
  pdf.text('Scope 1 emissions are direct emissions from sources owned or controlled by the reporting company.' ,8, 1020);
  pdf.text('These emissions come from activities like using fossil fuels to generate electricity, operating vehicles, and using refrigerants.', 8, 1040);

  pdf.text('Scope 2 emissions are indirect emissions from the generation and consumption of purchased or acquired electricity, steam, heat, and cooling.' , 8, 1060);
  pdf.text('These emissions can come from activities such as using electricity to power lights, computers, and other equipment.', 8, 1080);

  pdf.text('Scope 3 emissions are all other indirect emissions that occur in the value chain , excluding upstream and downstream transportation and distribution. ', 8, 1100);
  pdf.text('These emissions can come from activities such as the transportation of raw materials, the production of goods, and the disposal of products.', 8, 1120);

  let currentY = 500;  
  currentY += 20;

  // Add table
  const newTable = document.querySelector("#emissions-detailed-table-separate");
  const newData = [];
  const newHeaders = [];
  const amazonSearchUrls = [];

  for (let i = 0; i < newTable.rows.length; i++) {
    const row = newTable.rows[i];
    const rowData = [];
    for (let j = 0; j < row.cells .length; j++) {
if (i === 0) {
newHeaders.push(row.cells[j].textContent);
// Skip the first 2 cells (Category and Emissions Value)
if (j > 0&& j < row.cells.length - 1) {
// Extract the brand and model names from the header text
let headerText = row.cells[j].textContent;
let brandAndModel = headerText.split(' '); // Assuming the brand and model are separated by a space
let brand = brandAndModel[0];
let model = brandAndModel.slice(1).join(' ');  // Take all words after the brand as the model
let searchUrl = `https://www.amazon.co.uk/s?k=${encodeURIComponent(brand + ' ' + model)}`;
amazonSearchUrls.push({ searchQuery: brand + ' ' + model, searchUrl: searchUrl });
}
} else {
rowData.push(row.cells[j].textContent);
}
}
if (i !== 0) {
newData.push(rowData);
}
}

pdf.autoTable({
startY: currentY,
head: [newHeaders],
body: newData,
styles: {
cellPadding: 1,
fontSize: 16,
valign: 'middle',
overflow: 'linebreak',
tableWidth: 'wrap',
lineWidth: 0.5,
},
headStyles: {
fillColor: [221, 221, 221],
textColor: [0, 0, 0],
},
columnStyles: {
0: { cellWidth: 'wrap' },
1: { cellWidth: 'wrap' },
2: { cellWidth: 'wrap' },
},
didDrawPage: addHeaderFooter,
});

currentY = pdf.lastAutoTable.finalY + 20;

// Add Amazon search links for each brand and model
pdf.text('Search Amazon for the above products. Click on Product names:', 10, currentY);
for (const amazonSearch of amazonSearchUrls) {
currentY += 15;
pdf.textWithLink(amazonSearch.searchQuery, 10, currentY, { url: amazonSearch.searchUrl });
currentY += 20;
}

pdf.save("Carbon Emissions Report.pdf");
});




