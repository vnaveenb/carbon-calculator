function initializeForm(form) {
  // Attach all event listeners for the given form.
  // Replace all occurrences of `document.querySelector` with `form.querySelector`

  async function fetchAndPopulateDropdown(route, prevSelections, dropdownSelector) {
    const queryString = prevSelections.map(s => `${s.name}=${s.value}`).join('&');
    console.log("Fetching data from:", route);
    const response = await fetch(`${route}?${queryString}`);
    const data = await response.json();
    console.log("Fetched data:", data);

    const dropdown = form.querySelector(dropdownSelector);
    dropdown.innerHTML = '<option value="">Please select an option</option>';
    data.forEach(item => {
      const option = document.createElement('option');
      option.value = item;
      option.textContent = item;
      dropdown.appendChild(option);
    });
  }

  form.querySelector('.brand').addEventListener('change', async (e) => {
  fetchAndPopulateDropdown('/user/unique-models', [{ name: 'brand', value: e.target.value }], '.model');
});

form.querySelector('.model').addEventListener('change', async (e) => {
  fetchAndPopulateDropdown('/user/unique-processors', [{ name: 'brand', value: form.querySelector('.brand').value }, { name: 'model', value: e.target.value }], '.processor');
});

form.querySelector('.processor').addEventListener('change', async (e) => {
  fetchAndPopulateDropdown('/user/unique-ram', [{ name: 'brand', value: form.querySelector('.brand').value }, { name: 'model', value: form.querySelector('.model').value }, { name: 'processor', value: e.target.value }], '.ram');
});

form.querySelector('.ram').addEventListener('change', async (e) => {
  fetchAndPopulateDropdown('/user/unique-storage', [{ name: 'brand', value: form.querySelector('.brand').value }, { name: 'model', value: form.querySelector('.model').value }, { name: 'processor', value: form.querySelector('.processor').value }, { name: 'ram', value: e.target.value }], '.storage');
});

form.querySelector('.storage').addEventListener('change', async (e) => {
  fetchAndPopulateDropdown('/user/unique-screen-size', [{ name: 'brand', value: form.querySelector('.brand').value }, { name: 'model', value: form.querySelector('.model').value }, { name: 'processor', value: form.querySelector('.processor').value }, { name: 'ram', value: form.querySelector('.ram').value }, { name: 'storage', value: e.target.value }], '.screen_size');
});

form.querySelector('.screen_size').addEventListener('change', async (e) => {
  fetchAndPopulateDropdown('/user/unique-location', [{ name: 'brand', value: form.querySelector('.brand').value }, { name: 'model', value: form.querySelector('.model').value }, { name: 'processor', value: form.querySelector('.processor').value }, { name: 'ram', value: form.querySelector('.ram').value }, { name: 'storage', value: form.querySelector('.storage').value }, { name: 'screen_size', value: e.target.value }], '.location');
});


  let pieChart;
  let barChart;



  function updateTableAndCharts(chartDataArray) {
  console.log("Received chart data:", chartDataArray);

  const totalEmissions = {};
  chartDataArray.forEach(chartData => {
    Object.keys(chartData).forEach(key => {
      if (!totalEmissions[key]) {
        totalEmissions[key] = 0;
      }
      totalEmissions[key] += chartData[key];
    });
  });

  console.log("Total emissions:", totalEmissions);

  const categories = [
    'end_of_life',
    'product_use',
    'transport',
    'packaging',
    'production',
    'scope_2',
    'scope_3',
    'total', // Add the 'total' category
  ];

  // Calculate the total emissions for each product and add it to the chartDataArray
  chartDataArray = chartDataArray.map(productData => {
    const totalEmissionsForProduct = categories.reduce((total, category) => {
      if (category === 'total') return total; // Skip the 'total' category
      const value = productData[category.toLowerCase().replace(' ', '_')];
      return total + value;
    }, 0);
    return { ...productData, total: totalEmissionsForProduct };
  });

  const detailedTableBody = document.querySelector('.detailed-emissions-table tbody');
  detailedTableBody.innerHTML = '';
  
  let sumOfTotalEmissions = 0;

  chartDataArray.forEach((productData, index) => {
    const row = document.createElement('tr');

    const productCell = document.createElement('td');
    productCell.textContent = `Product ${index + 1}`;
    row.appendChild(productCell);
    
    const totalEmissionsForProduct = productData.total;
    sumOfTotalEmissions += totalEmissionsForProduct;
    console.log("Product", index + 1, "total emissions:", totalEmissionsForProduct);
    console.log("Current sum of total emissions:", sumOfTotalEmissions);


    categories.forEach(category => {
      const value = productData[category.toLowerCase().replace(' ', '_')];
      const valueCell = document.createElement('td');
      valueCell.textContent = value;
      row.appendChild(valueCell);
    });
    console.log("Final sum of total emissions:", sumOfTotalEmissions);


    detailedTableBody.appendChild(row);
  });

    // Update the pie chart

// Custom Code
const centerTextPlugin = {
  id: "centerText",
  beforeDraw: function (chart, args, options) {
    if (options.center) {
      var ctx = chart.ctx;
      var centerConfig = options.center;
      var fontStyle = centerConfig.fontStyle || "Arial";
      var txt = centerConfig.text;
      var color = centerConfig.color || "#000";
      var sidePadding = centerConfig.sidePadding || 20;
      var sidePaddingCalculated = (sidePadding / 100) * (chart.innerRadius * 2);
      ctx.font = "10px " + fontStyle;

      var stringWidth = ctx.measureText(txt).width;
      var elementWidth = chart.innerRadius * 2 - sidePaddingCalculated;
      var widthRatio = elementWidth / stringWidth;
      var newFontSize = Math.floor(30 * widthRatio);
      var elementHeight = chart.innerRadius * 2;
      var fontSizeToUse = Math.min(newFontSize, elementHeight);
      ctx.textAlign = "center";
      ctx.textBaseline = "middle";
      var centerX = (chart.chartArea.left + chart.chartArea.right) / 2;
      var centerY = (chart.chartArea.top + chart.chartArea.bottom) / 2;
      ctx.font = fontSizeToUse + "px " + fontStyle;
      ctx.fillStyle = color;

      // Calculate the total emissions value for the center text
      const totalEmissionsValue = chart.data.datasets[0].data.reduce(
        (acc, curr) => acc + curr,
        0
      );
      // Update the center text
      const centerText = "Total Emissions: " + totalEmissionsValue;

      ctx.fillText(centerText, centerX, centerY);
    }
  },
};




const ctx = document.getElementById("pieChart").getContext("2d");

if (pieChart) {
  pieChart.destroy();
}

const emissionsData = categories.map((category) =>
  totalEmissions[category.toLowerCase().replace(" ", "_")]
);
const totalEmissionsValue = emissionsData.reduce(
  (acc, curr) => acc + curr,
  0
);

pieChart = new Chart(ctx, {
  type: "doughnut",
  data: {
    labels: categories,
    datasets: [
      {
        data: emissionsData,
        backgroundColor: [
          "#FF6384",
          "#36A2EB",
          "#FFCE56",
          "#4BC0C0",
          "#9966FF",
          "#FF9F40",
          "#FF6384",
        ],
      },
    ],
  },
  options: {
    plugins: {
      centerText: {
        center: {
          text: "Total Emissions: " + sumOfTotalEmissions,
          color: "#000",
          fontStyle: "Arial",
          sidePadding: 20,
        },
      },
    },
  },
  plugins: [centerTextPlugin],
});


    // Update the bar chart
    const barCtx = document.getElementById('barChart').getContext('2d');

    if (barChart) {
        barChart.destroy();
    }

    barChart = new Chart(barCtx, {
        type: 'bar',
        data: {
            labels: categories,
            datasets: [{
                data: categories.map(category => totalEmissions[category.toLowerCase().replace(' ', '_')]),
                backgroundColor: [
                    '#FF6384',
                    '#36A2EB',
                    '#FFCE56',
                    '#4BC0C0',
                    '#9966FF',
                    '#FF9F40',
                    '#FF6384',
                ],
            }],
        },
    });
}



function checkFormFields(form) {
  const requiredFields = ['brand', 'model', 'processor', 'ram', 'storage', 'screen_size', 'location', 'quantity', 'years'];
  for (const field of requiredFields) {
    const input = form[field];
    if (input.value === '') {
      return false;
    }
  }
  return true;
}
function showWarningMessage(message) {
  $('#error-message').text(message).show();
  console.log("insied warning message");
}

async function fetchDataAndRenderContent() {
  const form = document.querySelector('#carbon-emission-form');

  if (!checkFormFields(form)) {
    document.querySelector('#error-message').style.display = 'block';
    showWarningMessage('Please fill out all form fields.');
    console.log("inside check form");
    return;
  }
  console.log("outside check form");
  document.querySelector('#error-message').style.display = 'none';
  document.querySelector('.content').style.display = 'block';

  const productFormContainers = document.querySelectorAll('.product-form-container');

  const allChartData = [];

  for (const formContainer of productFormContainers) {
    const formData = new FormData(formContainer.querySelector('form'));

    const response = await fetch('/user/chart-data?' + new URLSearchParams(formData));
    const chartData = await response.json();
    allChartData.push(chartData);
  }

  console.log('Fetched data:', allChartData);
  console.log('Individual chart data:', allChartData.map(data => JSON.stringify(data)));

  updateTableAndCharts(allChartData);
}

document.querySelector('#submit-all').addEventListener('click', (event) => {
  event.preventDefault();
  fetchDataAndRenderContent();
});


















  const brandDropdown = form.querySelector('.brand');
  brandDropdown.dispatchEvent(new Event('change'));
  fetchAndPopulateDropdown('/user/unique-brands', [], '.brand');
}

// Initialize the main form.
initializeForm(document.querySelector('.product-form-container'));



document.querySelector('#remove-product').addEventListener('click', () => {
