// Create a header cell for Scope and append it to headerRow
let scopeHeaderCell = document.createElement('th');
scopeHeaderCell.textContent = 'Scope';
headerRow.appendChild(scopeHeaderCell);

tableHead.appendChild(headerRow);
// Get a reference to the table body
const detailedTableBodySeparate = document.querySelector('#emissions-detailed-table-separate tbody');
detailedTableBodySeparate.innerHTML = '';

// Create rows for each category
for (const category in scopes) {
  const row = document.createElement('tr');

  // Create a cell for the category and append it to the row
  const categoryCell = document.createElement('td');
  categoryCell.textContent = category;
  row.appendChild(categoryCell);

  // Create a cell for each product's emissions in this category and append them to the row
  for (const productData of chartDataArray) {
    const valueCell = document.createElement('td');
    valueCell.textContent = productData[category] || 'N/A';
    row.appendChild(valueCell);
  }

  // Create a cell for the scope and append it to the row
  const scopeCell = document.createElement('td');
  scopeCell.textContent = scopes[category];
  row.appendChild(scopeCell);

  detailedTableBodySeparate.appendChild(row);
}

// Initialize DataTables when the table is available
$(document).ready(function() {
  $('#emissions-detailed-table-separate').DataTable({ pageLength: 15 });
});



















    // Update the pie chart

const centerTextPlugin = {
  id: "centerText",
  beforeDraw: function (chart, args, options) {
    if (options.center) {
      var ctx = chart.ctx;
      var centerConfig = options.center;
      var fontStyle = centerConfig.fontStyle || "Arial";
      var txt = centerConfig.text;
      var color = centerConfig.color || "#000";
      var sidePadding = centerConfig.sidePadding || 20;
      var sidePaddingCalculated = (sidePadding / 100) * (chart.innerRadius * 2);
      ctx.font = "10px " + fontStyle;

      var stringWidth = ctx.measureText(txt).width;
      var elementWidth = chart.innerRadius * 2 - sidePaddingCalculated;
      var widthRatio = elementWidth / stringWidth;
      var newFontSize = Math.floor(30 * widthRatio);
      var elementHeight = chart.innerRadius * 2;
      var fontSizeToUse = Math.min(newFontSize, elementHeight);
      ctx.textAlign = "center";
      ctx.textBaseline = "middle";
      var centerX = (chart.chartArea.left + chart.chartArea.right) / 2;
      var centerY = (chart.chartArea.top + chart.chartArea.bottom) / 2;
      ctx.font = fontSizeToUse + "px " + fontStyle;
      ctx.fillStyle = color;

      // Calculate the total emissions value for the center text
      const totalEmissionsValue = chart.data.datasets[0].data.reduce(
        (acc, curr) => acc + curr,
        0
      );
      // Update the center text
      const centerText = "Total Emissions: " + totalEmissionsValue;

      ctx.fillText(centerText, centerX, centerY);
    }
  },
};




