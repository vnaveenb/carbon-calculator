                    <option value="">Please select a processor</option>
                  </select>
                </div>
  
                <div class="form-group col-md-6">
                  <label for="ram">RAM:</label>
                  <select id="ram" class="form-control ram" name="ram">
                    <option value="">Please select a RAM size</option>
                  </select>
                </div>
              </div>
  
              <div class="form-row">
                <div class="form-group col-md-6">
                  <label for="storage">Storage:</label>
                  <select id="storage" class="form-control storage" name="storage">
                    <option value="">Please select a storage size</option>
                  </select>
                </div>
  
                <div class="form-group col-md-6">
                  <label for="screen_size">Screen Size:</label>
                  <select id="screen_size" class="form-control screen_size" name="screen_size">
