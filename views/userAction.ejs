<%- include('header') %>

<!-- jsPDF + html2canvas -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.28/jspdf.plugin.autotable.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<div class="container py-4">
  <div class="page-header-bar">
    <h2><i class="fa-solid fa-calculator me-2"></i>Carbon Calculator</h2>
    <p>Select a device, set your region, and calculate the full lifecycle carbon footprint.</p>
  </div>

  <div id="error-message" class="alert alert-warning d-none" role="alert"></div>

  <!-- Product Forms Container -->
  <div class="product-forms-container" id="product-forms-container">
    <div class="form-card" id="form-0">
      <h6 class="fw-bold text-eco mb-3"><i class="fa-solid fa-laptop me-2"></i>Device 1</h6>
      <div class="row g-3">
        <div class="col-md-6">
          <label class="form-label fw-semibold">Brand</label>
          <select class="form-select brand-select" name="brand" required>
            <option value="">Select a brand</option>
          </select>
        </div>
        <div class="col-md-6">
          <label class="form-label fw-semibold">Model</label>
          <select class="form-select model-select" name="model" required>
            <option value="">Select a model</option>
          </select>
        </div>
        <div class="col-md-4">
          <label class="form-label fw-semibold">Country</label>
          <select class="form-select location-select" name="location" required>
            <% for (const code in countries) { %>
              <option value="<%= code %>"><%= countries[code].name %></option>
            <% } %>
          </select>
        </div>
        <div class="col-md-4">
          <label class="form-label fw-semibold">Quantity</label>
          <input type="number" class="form-control quantity-input" name="quantity" min="1" value="1" required>
        </div>
        <div class="col-md-4">
          <label class="form-label fw-semibold">Years of Use</label>
          <input type="number" class="form-control years-input" name="years" min="1" max="10" value="3" required>
        </div>
      </div>
    </div>
  </div>

  <!-- Action Buttons -->
  <div class="d-flex flex-wrap gap-2 mb-4">
    <button id="submit-all" class="btn btn-eco fw-semibold">
      <i class="fa-solid fa-paper-plane me-2"></i>Calculate Emissions
    </button>
    <button id="add-product" class="btn btn-outline-secondary fw-semibold">
      <i class="fa-solid fa-plus me-2"></i>Add Device
    </button>
    <button id="remove-product" class="btn btn-outline-danger fw-semibold">
      <i class="fa-solid fa-trash me-2"></i>Remove Last
    </button>
    <button id="download" class="btn btn-outline-secondary fw-semibold">
      <i class="fa-solid fa-file-arrow-down me-2"></i>Download PDF
    </button>
  </div>

  <!-- Results Table -->
  <div id="results-section" class="d-none">
    <div class="table-container mb-4">
      <h5 class="section-title">Emissions Breakdown (kg CO₂e)</h5>
      <div class="table-responsive">
        <table id="emissions-table" class="table table-hover align-middle">
          <thead class="table-dark"><tr></tr></thead>
          <tbody></tbody>
        </table>
      </div>
    </div>

    <!-- Charts -->
    <div class="row g-4 mb-4">
      <div class="col-lg-6">
        <div class="table-container">
          <h5 class="section-title">Component Breakdown</h5>
          <div class="chart-container" style="max-height:380px;">
            <canvas id="pieChart"></canvas>
          </div>
        </div>
      </div>
      <div class="col-lg-6">
        <div class="table-container">
          <h5 class="section-title">Emissions by Category</h5>
          <div class="bar-chart-container" style="max-height:380px;">
            <canvas id="barChart"></canvas>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
const { jsPDF } = window.jspdf;

// Country options pre-rendered by server
const COUNTRY_OPTIONS = `<% for (const code in countries) { %><option value="<%= code %>"><%= countries[code].name %></option><% } %>`;


let formCount = 1;
let pieChart, barChart;

const CATEGORIES = [
  'transportation','packaging','display','soc','battery',
  'power_supply_unit','optical_drive','storage_drive',
  'chassis','end_of_life','device_usage'
];
const LABELS = {
  transportation: 'Transportation', packaging: 'Packaging', display: 'Display',
  soc: 'Mainboard / SOC', battery: 'Battery', power_supply_unit: 'Power Supply',
  optical_drive: 'Optical Drive', storage_drive: 'Storage Drive',
  chassis: 'Chassis', end_of_life: 'End of Life', device_usage: 'Device Usage'
};
const SCOPES = {
  transportation:'Scope 1', packaging:'Scope 1', display:'Scope 1',
  soc:'Scope 1', battery:'Scope 1', power_supply_unit:'Scope 1',
  optical_drive:'Scope 1', storage_drive:'Scope 1', chassis:'Scope 1',
  end_of_life:'Scope 3', device_usage:'Scope 2'
};
const COLORS = [
  '#2d6a4f','#40916c','#74c69d','#b7e4c7','#d4a017','#f4a261',
  '#e76f51','#264653','#2a9d8f','#e9c46a','#a8dadc'
];

// ── Populate brand dropdown on page load ──
async function loadBrands(brandSelect) {
  const resp = await fetch('/user/unique-brands');
  const brands = await resp.json();
  brandSelect.innerHTML = '<option value="">Select a brand</option>';
  brands.forEach(b => {
    const opt = document.createElement('option');
    opt.value = b; opt.textContent = b;
    brandSelect.appendChild(opt);
  });
}

// ── Wire up a form card ──
function initForm(card) {
  const brandSel = card.querySelector('.brand-select');
  const modelSel = card.querySelector('.model-select');
  loadBrands(brandSel);

  brandSel.addEventListener('change', async () => {
    const brand = brandSel.value;
    modelSel.innerHTML = '<option value="">Loading…</option>';
    if (!brand) { modelSel.innerHTML = '<option value="">Select a model</option>'; return; }
    const resp = await fetch('/user/unique-models?brand=' + encodeURIComponent(brand));
    const models = await resp.json();
    modelSel.innerHTML = '<option value="">Select a model</option>';
    models.forEach(m => {
      const opt = document.createElement('option');
      opt.value = m; opt.textContent = m;
      modelSel.appendChild(opt);
    });
  });
}

// ── Add Device button ──
document.getElementById('add-product').addEventListener('click', () => {
  const container = document.getElementById('product-forms-container');
  const idx = formCount++;
  const card = document.createElement('div');
  card.className = 'form-card';
  card.id = 'form-' + idx;
  card.innerHTML = `
    <h6 class="fw-bold text-eco mb-3"><i class="fa-solid fa-laptop me-2"></i>Device ${idx + 1}</h6>
    <div class="row g-3">
      <div class="col-md-6">
        <label class="form-label fw-semibold">Brand</label>
        <select class="form-select brand-select" name="brand" required>
          <option value="">Select a brand</option>
        </select>
      </div>
      <div class="col-md-6">
        <label class="form-label fw-semibold">Model</label>
        <select class="form-select model-select" name="model" required>
          <option value="">Select a model</option>
        </select>
      </div>
      <div class="col-md-4">
        <label class="form-label fw-semibold">Country</label>
        <select class="form-select location-select" name="location" required>
          ${COUNTRY_OPTIONS}
        </select>
      </div>
      <div class="col-md-4">
        <label class="form-label fw-semibold">Quantity</label>
        <input type="number" class="form-control quantity-input" name="quantity" min="1" value="1" required>
      </div>
      <div class="col-md-4">
        <label class="form-label fw-semibold">Years of Use</label>
        <input type="number" class="form-control years-input" name="years" min="1" max="10" value="3" required>
      </div>
    </div>
  `;
  container.appendChild(card);
  initForm(card);
});

// ── Remove Last Device button ──
document.getElementById('remove-product').addEventListener('click', () => {
  const container = document.getElementById('product-forms-container');
  const cards = container.querySelectorAll('.form-card');
  if (cards.length > 1) cards[cards.length - 1].remove();
});

// ── Submit All ──
document.getElementById('submit-all').addEventListener('click', async () => {
  const errorEl = document.getElementById('error-message');
  errorEl.classList.add('d-none');

  const cards = document.querySelectorAll('#product-forms-container .form-card');
  const allData = [];

  for (const card of cards) {
    const brand = card.querySelector('.brand-select').value;
    const model = card.querySelector('.model-select').value;
    const location = card.querySelector('.location-select').value;
    const quantity = card.querySelector('.quantity-input').value;
    const years = card.querySelector('.years-input').value;

    if (!brand || !model) {
      errorEl.textContent = 'Please select a brand and model for each device.';
      errorEl.classList.remove('d-none');
      return;
    }

    const params = new URLSearchParams({ brand, model, location, quantity, years });
    const resp = await fetch('/user/chart-data?' + params);
    if (!resp.ok) {
      errorEl.textContent = `Could not load data for ${brand} ${model}. Try another selection.`;
      errorEl.classList.remove('d-none');
      return;
    }
    const chartData = await resp.json();
    allData.push(chartData);

    // Save search
    const total = CATEGORIES.reduce((s, k) => s + (chartData[k] || 0), 0);
    fetch('/user/save-search', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ brand, model, location, years, quantity, total_carbon_emissions: total })
    });
  }

  renderResults(allData);
  document.getElementById('results-section').classList.remove('d-none');
});

// ── Render table + charts ──
function renderResults(dataArray) {
  // Table header
  const thead = document.querySelector('#emissions-table thead tr');
  thead.innerHTML = '<th>Category</th>';
  dataArray.forEach(d => {
    const th = document.createElement('th');
    th.textContent = d.brand + ' ' + d.model;
    thead.appendChild(th);
  });
  const thScope = document.createElement('th');
  thScope.textContent = 'Scope';
  thead.appendChild(thScope);

  // Table body
  const tbody = document.querySelector('#emissions-table tbody');
  tbody.innerHTML = '';
  CATEGORIES.forEach(cat => {
    const tr = document.createElement('tr');
    tr.innerHTML = `<td class="fw-semibold">${LABELS[cat]}</td>`;
    dataArray.forEach(d => {
      const td = document.createElement('td');
      td.textContent = d[cat] != null ? Number(d[cat]).toFixed(2) : '0.00';
      tr.appendChild(td);
    });
    const tdScope = document.createElement('td');
    tdScope.innerHTML = `<span class="badge bg-secondary">${SCOPES[cat]}</span>`;
    tr.appendChild(tdScope);
    tbody.appendChild(tr);
  });

  // Initialize / reinitialize DataTable
  if ($.fn.DataTable.isDataTable('#emissions-table')) {
    $('#emissions-table').DataTable().destroy();
  }
  $('#emissions-table').DataTable({ pageLength: 15, paging: false, searching: false, info: false });

  // Aggregate totals
  const totals = {};
  CATEGORIES.forEach(cat => {
    totals[cat] = dataArray.reduce((s, d) => s + (d[cat] || 0), 0);
  });
  const grandTotal = Object.values(totals).reduce((a, b) => a + b, 0).toFixed(2);

  // Pie chart
  const centerPlugin = {
    id: 'centerText',
    beforeDraw(chart) {
      const { ctx, chartArea: { left, right, top, bottom } } = chart;
      const total = chart.data.datasets[0].data.reduce((a, b) => a + b, 0).toFixed(1);
      ctx.save();
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      ctx.font = 'bold 13px sans-serif';
      ctx.fillStyle = '#1b4332';
      ctx.fillText(`${total} kg`, (left + right) / 2, (top + bottom) / 2);
      ctx.restore();
    }
  };

  if (pieChart) pieChart.destroy();
  pieChart = new Chart(document.getElementById('pieChart').getContext('2d'), {
    type: 'doughnut',
    data: {
      labels: CATEGORIES.map(c => LABELS[c]),
      datasets: [{ data: CATEGORIES.map(c => totals[c]), backgroundColor: COLORS }]
    },
    options: { responsive: true, plugins: { legend: { position: 'bottom' } } },
    plugins: [centerPlugin]
  });

  // Bar chart
  if (barChart) barChart.destroy();
  barChart = new Chart(document.getElementById('barChart').getContext('2d'), {
    type: 'bar',
    data: {
      labels: CATEGORIES.map(c => LABELS[c]),
      datasets: [{ label: 'kg CO₂e', data: CATEGORIES.map(c => totals[c]), backgroundColor: COLORS }]
    },
    options: {
      responsive: true,
      plugins: { legend: { display: false } },
      scales: { x: { ticks: { maxRotation: 45, minRotation: 30 } } }
    }
  });
}

// ── PDF Download ──
document.getElementById('download').addEventListener('click', async () => {
  const pdf = new jsPDF('p', 'pt', 'a4');
  pdf.setFontSize(18);
  pdf.setTextColor(27, 67, 50);
  pdf.text('Carbon Emissions Report', 40, 40);
  pdf.setFontSize(10);
  pdf.setTextColor(100);
  pdf.text('Generated by Sustainable Tech Calculator  |  sustainabletechcalculator.com', 40, 56);

  const pieEl = document.getElementById('pieChart');
  const barEl = document.getElementById('barChart');
  if (pieEl && barEl) {
    const pieCanvas = await html2canvas(pieEl);
    const barCanvas = await html2canvas(barEl);
    pdf.addImage(pieCanvas.toDataURL('image/png'), 'PNG', 40, 70, 230, 230);
    pdf.addImage(barCanvas.toDataURL('image/png'), 'PNG', 300, 70, 260, 230);
  }

  const table = document.getElementById('emissions-table');
  if (table) {
    const headers = [...table.querySelectorAll('thead th')].map(th => th.textContent.trim());
    const body = [...table.querySelectorAll('tbody tr')].map(tr =>
      [...tr.querySelectorAll('td')].map(td => td.textContent.trim())
    );
    pdf.autoTable({
      startY: 320, head: [headers], body,
      headStyles: { fillColor: [27, 67, 50], textColor: 255 },
      styles: { fontSize: 9 }
    });
  }

  pdf.save('Carbon_Emissions_Report.pdf');
});

// ── Init first form ──
initForm(document.getElementById('form-0'));
</script>

<%- include('footer') %>
